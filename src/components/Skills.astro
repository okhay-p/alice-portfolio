---
const skills = [
  { icon: "brain", name: "Analytical Thinking", pct: 88 },
  { icon: "calendar-check", name: "Event Coordination", pct: 90 },
  { icon: "heart-handshake", name: "Service Mind", pct: 95 },
  { icon: "globe", name: "Multicultural Sensitivity", pct: 92 },
  { icon: "eye", name: "Adaptable & Observant", pct: 87 },
  { icon: "users", name: "Team Collaboration", pct: 90 },
];
---

<section id="skills" class="px-6 py-20 bg-cream">
  <div class="max-w-4xl mx-auto">
    <div class="text-center mb-14 fade-in">
      <p class="text-xs font-semibold tracking-widest uppercase mb-2 text-gold">What I Bring</p>
      <h2 class="font-heading text-3xl md:text-4xl font-bold text-navy">Skills & Strengths</h2>
    </div>
    <div class="grid md:grid-cols-2 gap-6">
      {skills.map((s) => (
        <div class="fade-in card-hover p-6 rounded-xl bg-white">
          <div class="flex items-center gap-3 mb-4">
            <div class="w-10 h-10 rounded-lg flex items-center justify-center bg-gold/20">
              <i data-lucide={s.icon} style="width:20px;height:20px;color:#C19A6B;"></i>
            </div>
            <h3 class="font-heading font-bold text-navy">{s.name}</h3>
          </div>
          <div class="w-full h-2 rounded-full overflow-hidden bg-beige-light">
            <div class="h-full rounded-full bg-gold" style={`width:${s.pct}%`}></div>
          </div>
        </div>
      ))}
    </div>
  </div>
</section>
